# =========================================================
# Trace — environment variable template
# Copy to .env.local and fill in real values (never commit .env.local).
# In production, set the same variables in the Vercel dashboard.
# =========================================================

# ---- App ----
# Local: http://localhost:3000  |  Vercel: https://<your-domain>.vercel.app
AUTH_URL=

# Auth.js session secret. Generate with: npx auth secret  (or openssl rand -base64 32)
AUTH_SECRET=

# ---- Google OAuth (Auth.js) ----
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ---- Neon PostgreSQL ----
# Pooled connection string (host contains "-pooler"). Used by the app at runtime.
DATABASE_URL=
# Direct connection string (no "-pooler"). Used only for Drizzle migrations.
DATABASE_URL_UNPOOLED=

# ---- Sanity CMS ----
# Non-secret, exposed to the client:
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01
# Secret, server-only:
SANITY_API_TOKEN=
